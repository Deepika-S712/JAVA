class Solution {
    public int maxProduct(int[] nums) {
        if (nums.length == 0) return 0;

        int n = nums.length;
        int maxprod = nums[0];

        for (int i = 0; i < n; i++) {
            int product = 1;
            for (int j = i; j < n; j++) {
                product *= nums[j];

                if (product > maxprod) {
                    maxprod = product;
                }
            }
        }

        return maxprod;
    }
}
